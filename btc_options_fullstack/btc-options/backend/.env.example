# Copy this to .env and fill in your values

# Delta Exchange API credentials
# Get from: https://www.delta.exchange/app/account/api-keys
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# For testnet (recommended for development):
# DELTA_BASE_URL=https://testnet-api.delta.exchange

# Redis (optional — in-memory fallback used if Redis unavailable)
REDIS_URL=redis://localhost:6379/0

# Frontend CORS origins (comma-separated in production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Black-Scholes risk-free rate
RISK_FREE_RATE=0.05

ENV=development
LOG_LEVEL=INFO
